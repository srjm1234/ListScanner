graph TD
    A(["check_path(path) 开始"])
    B[/"url = urljoin(target, path)"/]
    C["requests.get(url, timeout)"]
    D{"status == 404?"}
    E(["返回 (None, error/错误)"])
    F(["返回 (None, not_found/未找到)"])
    G["check_risk(path)"]
    H["构建 ScanResult"]
    I(["返回 (result, found/已发现)"])

    A --> B
    B --> C
    C -->|成功| D
    C -->|异常| E
    D -->|是| F
    D -->|否| G
    G --> H
    H --> I

    style A fill:#f0f0f0,stroke:#333,stroke-width:2px,color:#1a1a1a
    style B fill:#fafafa,stroke:#666,stroke-width:1.5px,color:#333
    style C fill:#f5f5f5,stroke:#555,stroke-width:1.5px,color:#1a1a1a
    style D fill:#fff,stroke:#444,stroke-width:2px,color:#1a1a1a
    style E fill:#e8e8e8,stroke:#888,stroke-width:1.5px,color:#333
    style F fill:#e8e8e8,stroke:#888,stroke-width:1.5px,color:#333
    style G fill:#f5f5f5,stroke:#555,stroke-width:1.5px,color:#1a1a1a
    style H fill:#f5f5f5,stroke:#555,stroke-width:1.5px,color:#1a1a1a
    style I fill:#f0f0f0,stroke:#333,stroke-width:2px,color:#1a1a1a
