graph TD
    START(["开始扫描"])
    INPUT[/"读取用户输入<br/>目标URL · 字典 · 扩展名 · 线程数 · 超时"/]
    VALIDATE{"URL 是否合法?"}
    ERROR1(["返回错误提示"])
    FIX["fix_url() 补全协议和斜杠"]
    READ[/"read_wordlist() 读取字典<br/>展开 %EXT% 占位符<br/>生成扩展名变体"/]
    CHECK{"字典是否为空?"}
    ERROR2(["返回错误: 字典为空"])
    TASK["创建扫描任务<br/>生成 task_id<br/>初始化统计数据"]
    POOL["启动线程池<br/>ThreadPoolExecutor<br/>max_workers = 线程数"]
    SUBMIT["提交所有路径到线程池<br/>每条路径调用 check_path()"]
    REQUEST["requests.get() 发送HTTP请求<br/>timeout = 用户设定值<br/>allow_redirects=False"]
    RESP{"响应状态码?"}
    NOT_FOUND["未发现(not_found) + 1<br/>跳过"]
    ERR["错误数(errors) + 1<br/>跳过"]
    RISK["check_risk() 风险分类<br/>判定 风险类型 + 风险等级"]
    RESULT["构建 ScanResult 对象<br/>加入结果列表"]
    NEXT{"还有未完成路径?"}
    SORT["按风险等级排序<br/>高 → 中 → 低"]
    REPORT["save_html_report()<br/>生成 HTML 报告文件"]
    DONE(["扫描完成<br/>返回结果 JSON"])

    START --> INPUT
    INPUT --> VALIDATE
    VALIDATE -->|否| ERROR1
    VALIDATE -->|是| FIX
    FIX --> READ
    READ --> CHECK
    CHECK -->|是| ERROR2
    CHECK -->|否| TASK
    TASK --> POOL
    POOL --> SUBMIT
    SUBMIT --> REQUEST
    REQUEST --> RESP
    RESP -->|404| NOT_FOUND
    RESP -->|异常| ERR
    RESP -->|2xx/3xx/4xx/5xx| RISK
    RISK --> RESULT
    NOT_FOUND --> NEXT
    ERR --> NEXT
    RESULT --> NEXT
    NEXT -->|是| REQUEST
    NEXT -->|否| SORT
    SORT --> REPORT
    REPORT --> DONE

    style START fill:#f0f0f0,stroke:#333,stroke-width:2px,color:#1a1a1a
    style DONE fill:#f0f0f0,stroke:#333,stroke-width:2px,color:#1a1a1a
    style ERROR1 fill:#e8e8e8,stroke:#888,stroke-width:1.5px,color:#333
    style ERROR2 fill:#e8e8e8,stroke:#888,stroke-width:1.5px,color:#333
    style INPUT fill:#fafafa,stroke:#666,stroke-width:1.5px,color:#333
    style READ fill:#fafafa,stroke:#666,stroke-width:1.5px,color:#333
